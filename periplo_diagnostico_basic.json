{
  "_meta": {
    "proyecto": "Periplo",
    "documento": "Banco diagnóstico - Nivel BASIC",
    "version": "1.0",
    "descripcion": "Esqueleto base para el HTML de diagnóstico. Contiene los 8 temas del Basic con 12 preguntas cada uno (4 fácil / 4 medio / 4 difícil), un mini-set de discriminación de estructuras, y un set de producción para el Examen 2 (revisión del maestro).",
    "arquitectura": {
      "examen_1": "Placement al registrarse. Adaptativo, 5-8 min, SOLO preguntas auto:true. Usa este banco filtrando por tier y skill.",
      "examen_2": "Refinamiento al suscribirse a clases. ~30 min. Incluye exam2_productive (auto:false, lo revisa el maestro).",
      "motor_adaptativo": "Recomendación: checkpoint tipo búsqueda binaria sobre los 8 temas (orden = dificultad). Acierto manda, velocidad solo desempata. Las preguntas L1:true confirman dominio real antes de saltar de tema.",
      "nota_para_dev": "Los 'skill' de los 4 temas de B1 coinciden EXACTO con CONFIG.basic.grammar de evaluaciones.html (skills_source: oficial), para que el Examen 1 auto-rellene el rubro del maestro. Los 4 temas de B2 traen skills PROPUESTAS por pedagogía (skills_source: propuesto) porque evaluaciones.html aún no tiene sub-skills para ellos: revísalas y súbelas a evaluaciones.html cuando quieras."
    }
  },
  "_legend": {
    "tier": "facil=reconocer | medio=producir | dificil=pensar/cazar error",
    "tool": "cuál de los 18 componentes renderiza la pregunta",
    "skill": "punto de fallo que mide (tag para el rubro)",
    "auto": "true=se autocalifica (Examen 1) | false=la revisa el maestro (Examen 2)",
    "L1": "true=caza un error típico de transferencia del español",
    "contrast": "true=las opciones malas vienen de estructuras que compiten (to be / do-does / modal / simple-continuous)",
    "campos_por_tool": {
      "multipleChoice": "options[], answer",
      "multipleResponse": "options[], answers[]",
      "trueFalse": "q (afirmación), answer (true/false)",
      "fillBlank": "q, hint, answer, accept[]",
      "wordForm": "q, options[], answer",
      "unscramble": "tokens[], answer",
      "matching": "pairs[{left,right}]",
      "categorySort": "pool[], buckets[{label, correct[]}]",
      "oddOneOut": "options[], answer (el que NO pertenece)",
      "dialogueFill": "context[], options[], answer",
      "contextMatch": "pairs[{situation, phrase}]",
      "spotError": "q, errorWord, answer (corregida)",
      "errorCorrection": "q, answer (corregida)",
      "audioQuestion": "audioText (se vuelve audio TTS), q, options[], answer",
      "openEnded / voiceReply": "prompt (auto:false)",
      "shortTranslation": "q (español), answer (inglés modelo), grading:'keywords' (auto:false)"
    }
  },

  "topics": [
    {
      "id": "modal_verbs",
      "level": "B1", "week": 1, "grammar": "Modal Verbs",
      "modales": ["can", "must", "will", "might", "should"],
      "vocab": "Verbs Pack 1 (Daily Routine) + Nouns Pack 1 (Modern Nomad)",
      "skills_source": "oficial",
      "questions": [
        { "id": "modal_F1", "skill": "Significado correcto", "tier": "facil", "tool": "multipleChoice", "auto": true, "L1": false, "q": "I have my laptop and a good signal, so I ___ work from anywhere.", "options": ["can", "must", "should", "might"], "answer": "can" },
        { "id": "modal_F2", "skill": "Estructura Negativa", "tier": "facil", "tool": "trueFalse", "auto": true, "L1": false, "q": "\"You mustn't take photos here\" means it is NOT allowed.", "answer": true },
        { "id": "modal_F3", "skill": "Significado correcto", "tier": "facil", "tool": "matching", "auto": true, "L1": false, "q": "Match each modal with its function.", "pairs": [ {"left": "Can", "right": "Ability / permission"}, {"left": "Must", "right": "Obligation"}, {"left": "Should", "right": "Advice"}, {"left": "Might", "right": "Possibility"}, {"left": "Will", "right": "Future"} ] },
        { "id": "modal_F4", "skill": "Identifica al escuchar", "tier": "facil", "tool": "audioQuestion", "auto": true, "L1": false, "audioText": "You should charge your power bank before you leave.", "q": "What is the speaker doing?", "options": ["Giving advice", "Giving an order", "Asking permission", "Making a prediction"], "answer": "Giving advice" },
        { "id": "modal_M1", "skill": "Significado correcto", "tier": "medio", "tool": "fillBlank", "auto": true, "L1": false, "q": "I'm not sure about my plans. I ___ visit my family this weekend.", "hint": "posibilidad (no es seguro)", "answer": "might" },
        { "id": "modal_M2", "skill": "Estructura Interrogativa", "tier": "medio", "tool": "unscramble", "auto": true, "L1": false, "tokens": ["Where", "can", "I", "buy", "a", "ticket", "?"], "answer": "Where can I buy a ticket?" },
        { "id": "modal_M3", "skill": "Aplica estructura fluida", "tier": "medio", "tool": "dialogueFill", "auto": true, "L1": false, "context": ["A: I can't find my passport!", "B: ___"], "options": ["You should look in your backpack.", "You must look in your backpack.", "You might look in your backpack.", "You will look in your backpack."], "answer": "You should look in your backpack." },
        { "id": "modal_M4", "skill": "Estructura Negativa", "tier": "medio", "tool": "fillBlank", "auto": true, "L1": false, "q": "There is no signal here, so I ___ send the email.", "hint": "no puedo (negativo de can)", "answer": "can't", "accept": ["cannot", "can not"] },
        { "id": "modal_D1", "skill": "Omisión del 'to'", "tier": "dificil", "tool": "multipleResponse", "auto": true, "L1": true, "contrast": true, "q": "Select ALL the grammatically correct sentences.", "options": ["I can help you tomorrow.", "I can to help you tomorrow.", "She won't buy a new charger.", "He should drives carefully."], "answers": ["I can help you tomorrow.", "She won't buy a new charger."] },
        { "id": "modal_D2", "skill": "Omisión del 'to'", "tier": "dificil", "tool": "spotError", "auto": true, "L1": true, "q": "You should to charge your power bank.", "errorWord": "to", "answer": "You should charge your power bank." },
        { "id": "modal_D3", "skill": "Estructura Interrogativa", "tier": "dificil", "tool": "errorCorrection", "auto": true, "L1": true, "q": "Where I can buy a ticket?", "answer": "Where can I buy a ticket?" },
        { "id": "modal_D4", "skill": "Estructura Negativa", "tier": "dificil", "tool": "errorCorrection", "auto": true, "L1": true, "q": "You don't should buy that adapter.", "answer": "You shouldn't buy that adapter." }
      ]
    },

